{
  "services": {
    "write": {
      "name": "Write Label",
      "description": "Write a label image to a Gicisky device.",
      "fields": {
        "device_id": {
          "name": "Device",
          "description": "Gicisky device(s) to write to."
        },
        "payload": {
          "name": "Payload",
          "description": "Payload describing what to draw."
        },
        "rotate": {
          "name": "Rotate",
          "description": "Label rotation in degrees (0, 90, 180, 270). Default: 0."
        },
        "background": {
          "name": "Background",
          "description": "Background color (white, black, red, yellow). Default: white."
        },
        "threshold": {
          "name": "Black Threshold",
          "description": "Black binarization threshold (0-255). Default: 128."
        },
        "red_threshold": {
          "name": "Red Threshold",
          "description": "Red binarization threshold (0-255). Default: 128."
        },
        "dry_run": {
          "name": "Dry Run",
          "description": "Generate the image without sending it to the device."
        }
      }
    },
    "write_guarded": {
      "name": "Write Guarded Label",
      "description": "Write a label image with guards applied (duplicate, write lock, debounce).",
      "fields": {
        "device_id": {
          "name": "Device",
          "description": "Gicisky device(s) to write to."
        },
        "payload": {
          "name": "Payload",
          "description": "Payload describing what to draw."
        },
        "rotate": {
          "name": "Rotate",
          "description": "Label rotation in degrees (0, 90, 180, 270). Default: 0."
        },
        "background": {
          "name": "Background",
          "description": "Background color (white, black, red, yellow). Default: white."
        },
        "threshold": {
          "name": "Black Threshold",
          "description": "Black binarization threshold (0-255). Default: 128."
        },
        "red_threshold": {
          "name": "Red Threshold",
          "description": "Red binarization threshold (0-255). Default: 128."
        },
        "dry_run": {
          "name": "Dry Run",
          "description": "Generate the image without sending it to the device."
        },
        "debounce_override_ms": {
          "name": "Debounce Override",
          "description": "Override the configured debounce delay for this call (0 = immediate)."
        }
      }
    }
  },
  "entity": {
    "sensor": {
      "write_duration": { "name": "Write Duration" },
      "failure_count": { "name": "Failure Count" },
      "last_failure_time": { "name": "Last Failure Time" }
    },
    "binary_sensor": {
      "connectivity": { "name": "Connectivity" },
      "display_in_sync": { "name": "Display In Sync" }
    },
    "image": {
      "last_updated_content": { "name": "Last Updated Content" },
      "preview_content": { "name": "Preview Content" }
    },
    "text": {
      "alias": { "name": "Alias" }
    },
    "switch": {
      "write_lock": { "name": "Write Lock" }
    }
  },
  "config": {
    "flow_title": "{name}",
    "step": {
      "user": {
        "description": "[%key:component::bluetooth::config::step::user::description%]",
        "data": {
          "address": "[%key:common::config_flow::data::device%]"
        }
      },
      "bluetooth_confirm": {
        "description": "[%key:component::bluetooth::config::step::bluetooth_confirm::description%]"
      }
    },
    "abort": {
      "not_supported": "This device is not supported.",
      "no_devices_found": "[%key:common::config_flow::abort::no_devices_found%]",
      "already_in_progress": "[%key:common::config_flow::abort::already_in_progress%]",
      "already_configured": "[%key:common::config_flow::abort::already_configured_device%]"
    }
  },
  "options": {
    "step": {
      "init": {
        "title": "Gicisky Options",
        "description": "Adjust how images are written to the device.",
        "data": {
          "retry_count": "Retry Count",
          "write_delay_ms": "Write Delay (ms)",
          "prevent_duplicate_send": "Prevent Duplicate Send",
          "debounce_ms": "Debounce Delay (ms)"
        },
        "data_description": {
          "retry_count": "Number of times to retry writing to the device before giving up.",
          "write_delay_ms": "Delay between each chunk written to the device. Increase if writes are unreliable.",
          "prevent_duplicate_send": "Skip writing when the new image is identical to the last one sent.",
          "debounce_ms": "Delay before writing to device. New writes cancel pending ones. 0 = disabled (immediate write)."
        }
      }
    }
  }
}
